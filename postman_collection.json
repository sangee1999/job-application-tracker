{
  "info": {
    "name": "Job Application Tracker API",
    "description": "API collection for Job Application Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Application",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company\": \"Tech Company Inc\",\n  \"position\": \"Senior Developer\",\n  \"application_date\": \"2026-02-26\",\n  \"status\": \"Applied\",\n  \"notes\": \"Great opportunity\"\n}"
        },
        "url": {
          "raw": "https://your-api-gateway-url/applications",
          "protocol": "https",
          "host": ["your-api-gateway-url"],
          "path": ["applications"]
        }
      }
    },
    {
      "name": "Get Applications",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://your-api-gateway-url/applications",
          "protocol": "https",
          "host": ["your-api-gateway-url"],
          "path": ["applications"]
        }
      }
    },
    {
      "name": "Update Application",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Interview\",\n  \"notes\": \"Interview scheduled for Feb 28\"\n}"
        },
        "url": {
          "raw": "https://your-api-gateway-url/applications/{id}",
          "protocol": "https",
          "host": ["your-api-gateway-url"],
          "path": ["applications", "{id}"]
        }
      }
    },
    {
      "name": "Delete Application",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "https://your-api-gateway-url/applications/{id}",
          "protocol": "https",
          "host": ["your-api-gateway-url"],
          "path": ["applications", "{id}"]
        }
      }
    },
    {
      "name": "Upload Resume",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"file_name\": \"resume.pdf\",\n  \"content_type\": \"application/pdf\",\n  \"file_content\": \"base64_encoded_file_content_here\"\n}"
        },
        "url": {
          "raw": "https://your-api-gateway-url/resume/upload",
          "protocol": "https",
          "host": ["your-api-gateway-url"],
          "path": ["resume", "upload"]
        }
      }
    }
  ]
}
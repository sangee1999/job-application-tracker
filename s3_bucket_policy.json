{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowLambdaReadWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "lambda.amazonaws.com"
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::job-application-tracker-resumes/*"
    }
  ]
}